# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka_host:9092
KAFKA_TOPIC=monitoring_metrics
KAFKA_CONSUMER_GROUP=your_consumer_group

# InfluxDB
INFLUX_URL=http://influx_host:8086
INFLUX_TOKEN=your_influx_token_here
INFLUX_ORG=your-org
INFLUX_BUCKET=metrics

# TimescaleDB / PostgreSQL
PG_HOST=postgres_host
PG_PORT=5432
PG_DB=hpc_monitoring
PG_USER=admin
PG_PASS=change_me